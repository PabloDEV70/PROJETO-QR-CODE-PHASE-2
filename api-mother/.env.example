# ===========================================
# Environment Configuration Template
# ===========================================
# Copy this file to .env and configure values
# ⚠️  DO NOT commit .env file to version control!
# ⚠️  Use GitHub Variables for sensitive credentials

# Application
NODE_ENV=production
PORT=3027

# ===========================================
# SQL Server Connection
# ===========================================
# Configure for your environment
SQLSERVER_SERVER=your-sql-server
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=SANKHYA_PROD
SQLSERVER_ENCRYPT=true
SQLSERVER_TRUST_SERVER_CERTIFICATE=false

# Connection Pool
SQLSERVER_POOL_MIN=2
SQLSERVER_POOL_MAX=10
SQLSERVER_CONNECTION_TIMEOUT=30000
SQLSERVER_REQUEST_TIMEOUT=30000

# ===========================================
# Database Credentials
# ===========================================
# CRUD User (Standard operations)
SQLSERVER_CRUD_USER=YOUR_CRUD_USER
SQLSERVER_CRUD_PASSWORD=YOUR_CRUD_PASSWORD

# SA User (Special operations - RARE)
SQLSERVER_SA_USER=YOUR_SA_USER
SQLSERVER_SA_PASSWORD=YOUR_SA_PASSWORD
ENABLE_SA_USER=false
ENABLE_SA_FOR_TRIGGERS=false
ENABLE_SA_FOR_PROCEDURES=false
ENABLE_SA_FOR_VIEWS=false
ENABLE_SA_FOR_FUNCTIONS=false

# ===========================================
# JWT Authentication
# ===========================================
# Use strong secret in production
JWT_SECRET=YOUR_JWT_SECRET_FROM_GITHUB_VARIABLES
JWT_EXPIRATION=3600

# CORS Configuration
# Use '*' para permitir todas as origens (desenvolvimento)
# Use lista separada por vírgula para produção
# Exemplo produção: CORS_ORIGINS=https://app.empresa.com,https://admin.empresa.com
CORS_ORIGINS=*

# ===========================================
# Network Bypass (for trusted external services)
# ===========================================
# Allows trusted services to bypass the network guard IP check
# Generate with: openssl rand -hex 32
# NETWORK_BYPASS_KEY=your_secret_key_here

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=info
LOG_FORMAT=json

# ===========================================
# Rate Limiting
# ===========================================
# Global rate limiting (aplica a todos os endpoints)
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100

# Login rate limiting (proteção contra brute force)
# Configurado diretamente no controller: 5 tentativas/minuto
# Refresh token: 10 tentativas/minuto

# ===========================================
# Mutation - Write Operations
# ===========================================
# Enable/disable write operations per environment
MUTATION_ENABLED_TESTE=true
MUTATION_ENABLED_TREINA=false
MUTATION_ENABLED_PROD=false

# Mutation Limits (optional)
MUTATION_MAX_INSERT_BATCH=100
MUTATION_MAX_UPDATE_ROWS=50
MUTATION_MAX_DELETE_ROWS=10

# ===========================================
# Table Write Permissions
# ===========================================
# ─── Redis (token revocation) ───────────────────────────
# Optional: if set, token blacklist persists across restarts
# If not set, uses in-memory fallback (tokens lost on restart)
# REDIS_URL=redis://:PASSWORD@192.168.1.9:6379

# Environment variable overrides (optional)
# See src/security/TABLE_PERMISSIONS_README.md for details

# Examples (uncomment and configure as needed):
# WRITE_ALLOWED_PROD_CUSTOM_TABLE=true
# WRITE_ALLOWED_TABLES_PROD=TABLE1,TABLE2,TABLE3
# WRITE_ALLOWED_TABLES_TESTE=*
# WRITE_ALLOWED_TABLES_TREINA=
