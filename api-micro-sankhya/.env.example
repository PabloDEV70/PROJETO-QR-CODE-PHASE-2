# Application environment: development | production | test
NODE_ENV=development

# HTTP server port
PORT=3000

# API Mother Configuration
# Base URL for the Sankhya DB Explorer API
API_MAE_BASE_URL=https://api-dbexplorer.example.com
# Number of retry attempts for failed API calls
API_MAE_RETRY_ATTEMPTS=3

# API key for public-query endpoint on API Mother (public data without JWT)
# Used by PublicQueryExecutor for unauthenticated public pages (armarios, etc)
API_MOTHER_PUBLIC_KEY=your-api-key-here

# Sankhya MGE Server (for file download URLs)
# Base URL of the Sankhya web server, used to build attachment download links
SANKHYA_MGE_URL=http://sistema.gigantaolocadora.com.br:8180/mge

# CORS: comma-separated allowed origins (empty = allow all in dev, block all in prod)
# CORS_ORIGIN=https://rdo.gigantaolocadora.com.br,http://localhost:3001

# Logging level: debug | info | warn | error
LOG_LEVEL=debug
