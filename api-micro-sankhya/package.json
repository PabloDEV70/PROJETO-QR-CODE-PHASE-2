{
  "name": "api-sankyhya-master",
  "version": "1.2.0",
  "description": "",
  "main": "index.js",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "tsc && tsc-alias && bash -c \"cd src && find . -name '*.sql' -exec install -D {} ../dist/src/{} \\;\"",
    "build:info": "bash scripts/generate-build-info.sh",
    "build:prod": "pnpm build:info && pnpm build",
    "start": "node dist/src/main.js",
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/main.ts",
    "test:unit": "jest --config jest-unit.config.js",
    "test:e2e": "jest --config jest-e2e.config.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/swagger": "^9.6.1",
    "@fastify/swagger-ui": "^5.2.5",
    "axios": "^1.13.6",
    "dotenv": "^17.2.3",
    "fastify": "^5.8.2",
    "fastify-metrics": "^12.1.0",
    "ioredis": "^5.10.1",
    "mssql": "^12.2.1",
    "pino": "^10.3.1",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.0",
    "jest": "^30.2.0",
    "pino-pretty": "^13.1.3",
    "ts-jest": "^29.4.6",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
